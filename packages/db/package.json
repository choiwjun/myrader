{
  "name": "@boina/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "bun -e \"console.error('db:generate is disabled. Write SQL files in packages/db/migrations and run bun run db:migrate.'); process.exit(1)\"",
    "db:migrate": "bun src/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0",
    "@boina/contracts": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0"
  }
}
