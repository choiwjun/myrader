# boina 환경 변수 스캐폴드 (.env.example)
# 실제 값은 .env 에 작성 — .env 는 절대 커밋 금지 (.gitignore 적용됨)
#
# 표기: [필수] 없으면 동작 불가 / [운영필수] production 에서 없으면 기능 차단(fail-fast)
#       [선택] 없으면 mock/기본값으로 동작(개발/CI) / [개발전용] production 금지
#
# ★ 운영 안전(수정라운드A): production(NODE_ENV=production)에서 외부 연동 실키가 비어 있으면
#   코드가 mock 으로 *조용히* fallback 하지 않고 차단한다(가짜 외부 응답·가짜 사업장 노출 0).
#   개발/CI/test 에서만 mock 으로 골격을 완주한다.

# ── App ───────────────────────────────────────────────────────
# [필수] 실행 모드. production 이면 외부 연동 실키 누락 시 mock 금지(fail-fast).
NODE_ENV="development"

# ── Database (Postgres + Drizzle) ─────────────────────────────
# [필수] Postgres 접속 URL. 모든 영속화(account/business/diagnosis/radar)의 출처.
#   미설정 시 DB 접근 route 는 500/throw. 빌드(env 없는 build)는 통과하나(동적 route),
#   런타임 DB 동작에는 반드시 필요하다.
DATABASE_URL="postgresql://boina:boina-dev-password@localhost:5436/boina_db"

# ── 인증 / 세션 ───────────────────────────────────────────────
# [필수] 세션 쿠키 HMAC-SHA256 서명 시크릿 (16자 이상 강한 무작위 값).
#   미설정/짧으면 세션 발급·검증이 throw → 로그인/설정 동작 불가.
#   생성 예: openssl rand -hex 32  /  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# [개발전용] dev-login 스텁 활성화(외부 IdP 미연동 골격 검증용).
#   ★ production 에서는 "true" 여도 코드가 강제 거부한다(NODE_ENV=production 가드).
DEV_LOGIN_ENABLED="false"

# 외부 IdP(소셜 로그인) — [OPEN] ADR-P1R1-001: 방식 미확정(기획 미명시).
#   결정 전까지 자격증명(이메일/비번) + dev-login 으로 세션·가드·account 토대만 동작.
# KAKAO_CLIENT_ID=""
# KAKAO_CLIENT_SECRET=""
# KAKAO_REDIRECT_URI=""

# ── 관리자 대시보드 ───────────────────────────────────────────
# [운영필수] 관리자 페이지(/admin) 접근 비밀번호. trim 후 비면 미설정으로 본다.
#   미설정이면 /admin·/api/admin/login 이 403(ADMIN_DISABLED) — 빈 비번 무방비 노출 0.
#   강한 무작위 값 권장. 생성 예: openssl rand -hex 24
ADMIN_PASSWORD=""

# ── 외부 데이터 소스 — 네이버 플레이스 검색 (가게 확정 S1) ─────
# [운영필수] 네이버 지역검색 API 키(둘 다 채워야 실 검색 활성).
#   비어 있으면: development/test → deterministic mock fixture(실 호출 0)로 완주.
#                production → 검색 자체를 차단(503 SEARCH_UNAVAILABLE) — 가짜 사업장 노출 0.
#   ★ 이 키는 경쟁사 SERP 자동발견(S3 경쟁·S4 갭)에도 사용된다(엔진 NaverSerpProvider) — 아래 참고.
# NAVER_CLIENT_ID=""
# NAVER_CLIENT_SECRET=""

# ── 외부 데이터 소스 — LLM (AI 가시성/추천 — 엔진) ────────────
# [선택] LLM provider 선택: auto(기본)|openai|anthropic|gemini|chatmock|mock.
#   미설정/auto → 사용 가능한 키를 자동 탐색, 최종 폴백은 rule-based(키 없이도 동작).
# LLM_PROVIDER="auto"
# [선택/운영권장] 실제 LLM 호출용 API 키(provider 별). 없으면 rule-based 폴백.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GEMINI_API_KEY=""           # (GOOGLE_AI_API_KEY 도 인식)
# [선택] 로컬/프록시 LLM(chatmock) — 개발용.
# CHATMOCK_BASE_URL=""
# CHATMOCK_API_KEY=""
# CHATMOCK_MODEL=""
# [선택] AI 일일 예산 상한(USD) — 초과 시 LLM 호출 게이팅(비용 가드).
# AI_DAILY_BUDGET_USD=""
# [선택] a11y(axe-core) 비활성 토글(헤드리스 미가용 환경에서 우회).
# AXE_CORE_DISABLED=""

# ── 경쟁사 SERP 자동발견 (S3 경쟁·S4 갭 — OQ-4 착수) ───────────
# 운영에서 grounded LLM 경쟁사 신호가 없을 때, 엔진 SERP+CompetitorDiscovery 로 경쟁사를
# 자동 발견한다(앱 배선 완료). provider 가용 시에만 활성 — 미구성이면 가짜 경쟁사 대신
# fail-fast(정직성). ⚠️ provider 미구성 시 운영 진단은 경쟁사 0 → 진단 실패. 무명 가게
# 실패율을 낮추려면 아래 중 하나를 채운다(SerpAPI 또는 위 NAVER 키 — 체인 시도).
# [운영권장] SerpAPI 키(있으면 SerpApiProvider). SERPAPI_API_KEY 도 인식(레거시 별칭).
# SERPAPI_KEY=""
#   또는 위 NAVER_CLIENT_ID/SECRET 만으로도 NaverSerpProvider 가 자동 사용된다(place 검색과 공유).
# [선택] provider 강제 지정: mock|serpapi|naver|auto(기본 auto = 키 자동 탐색).
# X_SAG_SERP=""
# [선택] 의료 업종(병원/약국 등) 경쟁사 포함 허용(기본 제외). "true" 면 포함.
# X_SAG_ALLOW_MEDICAL_COMPETITORS=""

# ── 백그라운드 잡 / 진단 처리 트리거 ──────────────────────────
# 잡 큐는 DbBacked(diagnoses.status 를 큐 저장소로 활용 — 별도 브로커 0, 재시작·멀티인스턴스 안전).
# enqueue 직후 백그라운드 drain 이 1차 경로지만, 서버리스(Vercel)는 응답 후 인스턴스가 종료될 수
# 있어 ★ cron 트리거가 사실상 진단 완료의 핵심 경로다.
# [운영필수] Vercel Cron 시크릿 — 미설정 시 /api/jobs/process 가 403 → 고아 잡 미복구(진단 영구 queued).
#   ⚠️ vercel.json 의 매분 cron("* * * * *")은 Vercel Pro 요금제 필요(Hobby 는 하루 1회만 실행).
# CRON_SECRET=""
# [선택] 외부 스케줄러/운영자 수동 트리거용 시크릿(x-jobs-secret 헤더). cron 대신/병행 사용.
# JOBS_PROCESS_SECRET=""
